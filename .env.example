APP_ENV=development
ISSUER_URL=http://localhost:8000

ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=30

DATABASE_URL=postgresql://fastauth:fastauth@db:5432/fastauth

REDIS_URL=redis://redis:6379
RATE_LIMIT_REQUESTS=10
RATE_LIMIT_WINDOW_SECONDS=60

MAX_LOGIN_ATTEMPTS=5
LOCKOUT_DURATION_SECONDS=900

KEY_ID=key-1

# Secondary key — uncomment during key rotation to serve both keys in JWKS
# SECONDARY_KEY_ID=key-0
# SECONDARY_PUBLIC_KEY_PATH=keys/public-old.pem

ADMIN_API_KEY=change-me-in-production

ALLOW_PUBLIC_REGISTRATION=true

POSTGRES_USER=fastauth
POSTGRES_PASSWORD=fastauth
POSTGRES_DB=fastauth
